# Enable rewrite engine
RewriteEngine On
RewriteBase /laptofy_MVC/public/

# 1) Skip existing files or folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --------------------------------------
# Friendly URLs mapping
# --------------------------------------

# User
RewriteRule ^home/?$ index.php?controller=home&action=index [L,QSA,NC]
RewriteRule ^show/([0-9]+)/?$ index.php?controller=home&action=show&id=$1 [L,QSA,NC]
RewriteRule ^filter/?$ index.php?controller=home&action=filter [L,QSA,NC]
RewriteRule ^price-filter/?$ index.php?controller=home&action=priceFilter [L,QSA,NC]

# Dashboard
RewriteRule ^dashboard$ index.php?controller=dashboard&action=index [L,QSA,NC]

# Delete Person
RewriteRule ^delete-person$ index.php?controller=Dashboard&action=deletePerson [L,QSA,NC]

# Profile
RewriteRule ^profile$ index.php?controller=profile&action=edit [L,QSA,NC]
RewriteRule ^profileupdate$ index.php?controller=profile&action=update [L,QSA,NC]

# Admin Auth
RewriteRule ^login$ index.php?controller=auth&action=login [L,QSA,NC]
RewriteRule ^logout$ index.php?controller=auth&action=logout [L,QSA,NC]
RewriteRule ^authenticate$ index.php?controller=auth&action=authenticate [L,QSA,NC]

# Person Auth (customer)
RewriteRule ^person-register$ index.php?controller=person&action=registerView [L,QSA,NC]
RewriteRule ^person-register-store$ index.php?controller=person&action=register [L,QSA,NC]
RewriteRule ^person-login$ index.php?controller=person&action=loginView [L,QSA,NC]
RewriteRule ^person-authenticate$ index.php?controller=person&action=login [L,QSA,NC]
RewriteRule ^person-logout$ index.php?controller=person&action=logout [L,QSA,NC]

# Wishlist
RewriteRule ^wishlist$ index.php?controller=wishlist&action=index [L,QSA,NC]
RewriteRule ^wishlist-add$ index.php?controller=wishlist&action=add [L,QSA,NC]
RewriteRule ^wishlist-remove$ index.php?controller=wishlist&action=remove [L,QSA,NC]

# Products
RewriteRule ^productlist$ index.php?controller=product&action=index [L,QSA,NC]
RewriteRule ^addproduct$ index.php?controller=product&action=create [L,QSA,NC]
RewriteRule ^editproduct/([0-9]+)$ index.php?controller=product&action=edit&id=$1 [L,QSA,NC]
RewriteRule ^deleteproduct/([0-9]+)$ index.php?controller=product&action=delete&id=$1 [L,QSA,NC]
RewriteRule ^viewproduct/([0-9]+)$ index.php?controller=product&action=show&id=$1 [L,QSA,NC]
RewriteRule ^updateproduct$ index.php?controller=product&action=update [L,QSA,NC]
RewriteRule ^storeproduct$ index.php?controller=product&action=store [L,QSA,NC]

# Brands
RewriteRule ^brandlist$ index.php?controller=brand&action=index [L,QSA,NC]
RewriteRule ^addbrand$ index.php?controller=brand&action=create [L,QSA,NC]
RewriteRule ^editbrand/([0-9]+)$ index.php?controller=brand&action=edit&id=$1 [L,QSA,NC]
RewriteRule ^deletebrand/([0-9]+)$ index.php?controller=brand&action=delete&id=$1 [L,QSA,NC]
RewriteRule ^viewbrand/([0-9]+)$ index.php?controller=brand&action=show&id=$1 [L,QSA,NC]
RewriteRule ^updatebrand$ index.php?controller=brand&action=update [L,QSA,NC]
RewriteRule ^storebrand$ index.php?controller=brand&action=store [L,QSA,NC]

# Person Profile
RewriteRule ^person-profile$ index.php?controller=Person&action=profile [L,QSA,NC]
RewriteRule ^person-profile-update$ index.php?controller=Person&action=updateProfile [L,QSA,NC]
RewriteRule ^person-change-password$ index.php?controller=Person&action=changePassword [L,QSA,NC]

# Default fallback
RewriteRule ^$ index.php [L,QSA,NC]